/* pages/videos/videos.wxss */

.header {
  padding: 30rpx 30rpx 10rpx;
}

.header-text {
  font-size: 26rpx;
  color: #999;
}

.upload-bar {
  padding: 20rpx 30rpx;
}

.upload-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1e3a5f 0%, #2c5282 100%);
  color: #FFF;
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(44, 82, 130, 0.3);
}

.upload-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.upload-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
  font-weight: 300;
}

/* 视频列表 - 2列布局 */
.video-list {
  padding: 0 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.video-card {
  width: calc((100% - 16rpx) / 2);
  background-color: #FFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s ease;
}

.video-card:active {
  transform: scale(0.98);
}

/* 视频封面 */
.video-cover {
  width: 100%;
  height: 240rpx;
  position: relative;
  overflow: hidden;
  background: #000;
}

.cover-image-element {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
  z-index: 1;
}

.cover-video-element {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
  z-index: 1;
}

/* 透明点击层：覆盖在 video 上方接收点击事件 */
.cover-tap {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 3;
}

/* 播放图标 */
.play-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  z-index: 2;
}

.play-circle {
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #FFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  padding-left: 6rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

/* 时长 */
.video-duration {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  padding: 4rpx 10rpx;
  background-color: rgba(0, 0, 0, 0.7);
  color: #FFF;
  font-size: 20rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

/* 置顶角标 */
.featured-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 6rpx 14rpx;
  background: linear-gradient(135deg, #FF8C42 0%, #FF6B35 100%);
  color: #FFF;
  font-size: 22rpx;
  border-radius: 8rpx;
  font-weight: 600;
  z-index: 5;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 53, 0.4);
}

/* 视频播放器内的置顶按钮 */
.player-action {
  position: absolute;
  top: 80rpx;
  right: 130rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background-color: rgba(255, 255, 255, 0.2);
  color: #FFF;
  border-radius: 30rpx;
  z-index: 11;
}

.player-action-icon {
  font-size: 32rpx;
}

.player-action-text {
  font-size: 26rpx;
}

/* 视频信息 */
.video-info {
  padding: 16rpx 18rpx;
}

.video-title {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.video-uploader {
  font-size: 28rpx;
  color: #1e3a5f;
  font-weight: 600;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.video-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.video-date {
  font-size: 22rpx;
  color: #999;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 8rpx;
}

.video-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.video-action {
  width: 48rpx;
  height: 48rpx;
  background-color: #F5F5F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.video-action:active {
  background-color: #E5E5E5;
}

/* 密码弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal {
  width: 600rpx;
  max-height: 80vh;
  background-color: #FFF;
  border-radius: 20rpx;
  padding: 50rpx 40rpx 40rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 16rpx;
}

.modal-hint {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-input {
  border: 2rpx solid #EEE;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  background-color: #FAFAFA;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  font-size: 30rpx;
  padding: 20rpx 0;
  border-radius: 50rpx;
  border: none;
}

.btn-cancel {
  background-color: #F5F5F5;
  color: #666;
}

.btn-confirm {
  background: linear-gradient(135deg, #1e3a5f 0%, #2c5282 100%);
  color: #FFF;
}

.btn-cancel::after, .btn-confirm::after {
  border: none;
}

/* 视频播放器 */
.player-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: #000;
  z-index: 999;
}

.player-container {
  position: relative;
  width: 100vw;
  height: 100vh;
}

.player-video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  display: block;
}

/* 关闭按钮区域 */
.player-close-area {
  position: absolute;
  top: 0;
  right: 0;
  width: 200rpx;
  height: 200rpx;
  z-index: 12;
}

.player-title {
  position: absolute;
  bottom: 60rpx;
  left: 0;
  right: 0;
  color: #FFF;
  font-size: 28rpx;
  padding: 0 40rpx;
  text-align: center;
  z-index: 11;
}

.player-close {
  position: absolute;
  top: 80rpx;
  right: 40rpx;
  width: 70rpx;
  height: 70rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 50rpx;
  color: #FFF;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  z-index: 10;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx 0 60rpx;
}

.load-more-text {
  font-size: 26rpx;
  color: #999;
  display: inline-block;
  padding: 10rpx 30rpx;
}

.load-more-end {
  color: #CCC;
  font-size: 24rpx;
}

