<view class="container">
  <!-- 头部统计 -->
  <view class="header">
    <text class="header-text">共 {{videos.length}} 个</text>
  </view>

  <!-- 上传按钮 -->
  <view class="upload-bar" bindtap="onTapUpload">
    <view class="upload-btn">
      <text class="upload-icon">⊕</text>
      <text class="upload-text">上传视频</text>
    </view>
  </view>

  <!-- 视频列表 -->
  <view class="video-list" wx:if="{{videos.length > 0}}">
    <view class="video-card {{item.featured ? 'featured' : ''}}" wx:for="{{videos}}" wx:key="_id" bindtap="onTapVideo" data-id="{{item._id}}" data-index="{{index}}">
      <!-- 视频封面：类似文件夹预览，自动静音循环 -->
      <view class="video-cover">
        <video
          class="cover-video-element"
          id="cover-{{item._id}}"
          src="{{item.playUrl}}"
          autoplay="{{true}}"
          muted="{{true}}"
          loop="{{true}}"
          controls="{{false}}"
          show-fullscreen-btn="{{false}}"
          show-center-play-btn="{{false}}"
          show-play-btn="{{false}}"
          object-fit="cover"
          binderror="onVideoError"
        ></video>
        <!-- 透明点击层：必须用这个才能触发点击事件，因为 video 是原生组件会拦截 -->
        <view class="cover-tap" catchtap="onTapVideo" data-id="{{item._id}}"></view>
        <!-- 播放图标 -->
        <view class="play-overlay">
          <view class="play-circle">▶</view>
        </view>
        <!-- 时长 -->
        <view class="video-duration" wx:if="{{item.duration}}">{{item.duration}}</view>
        <!-- 置顶角标 -->
        <view class="featured-badge" wx:if="{{item.featured}}">📌 置顶</view>
      </view>

      <!-- 视频信息 -->
      <view class="video-info">
        <view class="video-uploader">{{item.uploaderName}}</view>
        <view class="video-meta">
          <text class="video-date">{{item.createdAt}}</text>
          <view class="video-actions">
            <view class="video-action" catchtap="onDownload" data-id="{{item._id}}">⬇️</view>
            <view class="video-action delete" catchtap="onDelete" data-id="{{item._id}}" wx:if="{{isAdmin}}">🗑️</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:elif="{{!loading}}">
    <view class="empty-icon">🎬</view>
    <view class="empty-text">还没有视频</view>
    <view class="empty-hint">点击上方按钮上传第一个视频</view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 上传弹窗 -->
  <view class="modal-mask" wx:if="{{showUploadModal}}" catchtouchmove="onNoop">
    <view class="modal" catchtap="onNoop" catchtouchmove="onNoop">
      <view class="modal-title">上传视频</view>
      <view class="modal-hint">请输入您的姓名和上传密码</view>
      <input class="modal-input" maxlength="20" placeholder="您的姓名（用于显示上传者）" value="{{uploaderName}}" bindinput="onInputUploaderName" adjust-position="{{true}}" cursor-spacing="20" hold-keyboard="{{false}}" />
      <input class="modal-input" type="password" password maxlength="20" placeholder="上传密码" value="{{uploadPassword}}" bindinput="onInputPassword" adjust-position="{{true}}" cursor-spacing="20" hold-keyboard="{{false}}" style="margin-top: 20rpx;" />
      <view class="modal-buttons">
        <button class="btn-cancel" bindtap="onCloseUploadModal">取消</button>
        <button class="btn-confirm" bindtap="onConfirmUpload">确定</button>
      </view>
    </view>
  </view>

  <!-- 视频播放器 -->
  <view class="player-mask" wx:if="{{showPlayer && currentVideo.playUrl}}">
    <view class="player-container">
      <video
        id="player-video"
        class="player-video"
        src="{{currentVideo.playUrl}}"
        controls
        show-fullscreen-btn="{{false}}"
        show-center-play-btn="{{true}}"
        show-play-btn="{{true}}"
        enable-progress-gesture="{{true}}"
        enable-play-gesture="{{true}}"
        object-fit="contain"
        initial-time="0"
        binderror="onPlayerError"
      ></video>
      <view class="player-title" wx:if="{{currentVideo.description}}">{{currentVideo.description}}</view>
      <!-- 管理员操作：置顶/取消置顶 -->
      <view class="player-action" wx:if="{{isAdmin}}" catchtap="onToggleFeatured">
        <text class="player-action-icon">{{currentVideo.featured ? '📌' : '📍'}}</text>
        <text class="player-action-text">{{currentVideo.featured ? '取消置顶' : '设为置顶'}}</text>
      </view>
      <view class="player-close" catchtap="onClosePlayer">×</view>
      <view class="player-close-area" catchtap="onClosePlayer"></view>
    </view>
  </view>
</view>