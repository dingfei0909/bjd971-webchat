/* pages/photos/photos.wxss */

.header {
  padding: 30rpx 30rpx 10rpx;
}

.header-text {
  font-size: 26rpx;
  color: #999;
}

.upload-bar {
  padding: 20rpx 30rpx;
}

.upload-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1e3a5f 0%, #2c5282 100%);
  color: #FFF;
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(44, 82, 130, 0.3);
}

.upload-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.upload-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
  font-weight: 300;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
  gap: 10rpx;
}

.photo-item {
  width: calc((100% - 20rpx) / 3);
  aspect-ratio: 1 / 1;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #F5F5F5;
}

.photo-img {
  width: 100%;
  height: 100%;
  display: block;
}

.photo-desc {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 8rpx 12rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  color: #FFF;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.photo-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 8rpx 12rpx 10rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.75));
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  z-index: 2;
}

.photo-uploader {
  font-size: 22rpx;
  color: #FFF;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}

.photo-date {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.3;
}

/* 精选徽章 */
.featured-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #1e3a5f 0%, #2c5282 100%);
  color: #FFF;
  font-size: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 6rpx rgba(44, 82, 130, 0.4);
  z-index: 2;
}

/* 密码弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal {
  width: 600rpx;
  background-color: #FFF;
  border-radius: 20rpx;
  padding: 50rpx 40rpx 40rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 16rpx;
}

.modal-hint {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-input {
  border: 2rpx solid #EEE;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  background-color: #FAFAFA;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  font-size: 30rpx;
  padding: 20rpx 0;
  border-radius: 50rpx;
  border: none;
}

.btn-cancel {
  background-color: #F5F5F5;
  color: #666;
}

.btn-confirm {
  background: linear-gradient(135deg, #1e3a5f 0%, #2c5282 100%);
  color: #FFF;
}

.btn-cancel::after, .btn-confirm::after {
  border: none;
}

/* 预览弹窗 */
.preview-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.preview-container {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.preview-img {
  width: 100%;
  height: 70vh;
  display: block;
}

.preview-desc {
  color: #FFF;
  font-size: 28rpx;
  margin-top: 20rpx;
  padding: 0 40rpx;
  text-align: center;
}

.preview-date {
  color: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
  margin-top: 10rpx;
}

.preview-actions {
  display: flex;
  gap: 40rpx;
  margin-top: 60rpx;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
}

.preview-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 30rpx;
  border-radius: 12rpx;
}

.preview-action:active {
  background-color: rgba(255, 255, 255, 0.1);
}

.preview-action.delete {
  /* 管理员删除按钮 */
}

.action-icon {
  font-size: 50rpx;
  margin-bottom: 8rpx;
}

.action-text {
  color: #FFF;
  font-size: 24rpx;
}

.preview-close {
  position: absolute;
  top: 60rpx;
  right: 40rpx;
  width: 70rpx;
  height: 70rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 50rpx;
  color: #FFF;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}