/* pages/index/index.wxss */

/* ===== Hero 顶部区域 ===== */
.hero-container {
  position: relative;
  width: 100%;
  height: 280rpx;
  padding-top: 50rpx;
  background: linear-gradient(135deg, #1e3a5f 0%, #2c5282 50%, #1a3a5c 100%);
  overflow: hidden;
  box-sizing: border-box;
}

/* 顶部微妙渐变遮罩 */
.hero-gradient-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 80rpx;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0.15) 0%, transparent 100%);
  pointer-events: none;
}

/* 主内容区 */
.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: calc(100% - 50rpx);
  padding: 0 48rpx;
  box-sizing: border-box;
}

/* 左侧核心信息 */
.hero-main {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  padding-left: 28rpx;
  padding-top: 0rpx;
  align-items: flex-start;
}

.hero-meta {
  margin-left: -20rpx;
  margin-top: -48rpx;
  margin-bottom: 16rpx;
}

.hero-title {
  margin-left: 54rpx;
  margin-top: -6rpx;
}

.hero-meta {
  font-size: 24rpx;
  color: #c9a96e;
  letter-spacing: 4rpx;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 72rpx;
  font-weight: 700;
  color: #f5f5f7;
  letter-spacing: 6rpx;
  line-height: 1;
  text-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.3);
}

/* 右侧学校信息 */
.hero-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
}

.info-school {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.info-origin {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 8rpx;
}

.info-location {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 6rpx;
}

/* ===== 轮播区域 ===== */
.carousel-section {
  margin: 0 30rpx 30rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 8rpx;
  margin-bottom: 16rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.title-more {
  font-size: 24rpx;
  color: #2c5282;
  font-weight: 500;
}

.carousel {
  width: 100%;
  height: 380rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
}

.carousel-item {
  width: 100%;
  height: 100%;
  position: relative;
  background-color: #F5F5F5;
}

.carousel-img {
  width: 100%;
  height: 100%;
  display: block;
}

.carousel-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, transparent 100%);
}

.carousel-desc {
  color: #FFF;
  font-size: 26rpx;
  line-height: 1.4;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.3);
}

/* 空状态 */
.carousel-empty {
  height: 380rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #F0F4F8 0%, #D9E2EC 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #90AFD4;
}

.carousel-empty .empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.6;
}

.carousel-empty .empty-text {
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.carousel-empty .empty-hint {
  font-size: 24rpx;
  color: #999;
}

/* 加载中 */
.carousel-loading {
  height: 380rpx;
  border-radius: 20rpx;
  background-color: #FAFAFA;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}

/* ===== 入口卡片 ===== */
.entries {
  margin: 0 30rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.entry-card {
  display: flex;
  align-items: center;
  padding: 36rpx 32rpx;
  background-color: #FFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.entry-card:active {
  transform: scale(0.98);
  background-color: #FAFAFA;
}

.entry-icon {
  font-size: 60rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.entry-info {
  flex: 1;
}

.entry-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.entry-desc {
  font-size: 26rpx;
  color: #999;
}

.entry-arrow {
  font-size: 40rpx;
  color: #CCC;
  font-weight: 300;
}

.motto {
  margin: 50rpx 30rpx 60rpx;
  padding: 40rpx 20rpx;
  background-color: rgba(44, 82, 130, 0.08);
  border-radius: 16rpx;
  border-left: 6rpx solid #2c5282;
  text-align: center;
}

.motto-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.motto-from {
  font-size: 24rpx;
  color: #999;
}

/* 备案信息 */
.beian {
  margin: 60rpx 30rpx 30rpx;
  padding: 30rpx 24rpx;
  background-color: #F8F9FA;
  border-radius: 12rpx;
  border: 1rpx solid #E5E7EB;
}

.beian-row {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  line-height: 1.8;
  color: #6B7280;
}

.beian-label {
  color: #9CA3AF;
  flex-shrink: 0;
}

.beian-value {
  color: #4B5563;
}

.beian-link-text {
  color: #1e3a5f;
  text-decoration: underline;
}

.beian-tip {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #E5E7EB;
  font-size: 22rpx;
  color: #9CA3AF;
  text-align: center;
}

/* 上传入口提示 */
.upload-hint {
  margin: 40rpx 30rpx 0;
  padding: 30rpx 24rpx;
  background: linear-gradient(135deg, #FFF7E6 0%, #FFE7BA 100%);
  border-radius: 16rpx;
  border-left: 6rpx solid #FF8C42;
  text-align: center;
}

.hint-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #D46A1F;
  margin-bottom: 12rpx;
}

.hint-text {
  font-size: 26rpx;
  color: #8B6914;
  line-height: 1.6;
}

.hint-password {
  display: inline-block;
  padding: 4rpx 14rpx;
  margin: 0 4rpx;
  background-color: #D46A1F;
  color: #FFF;
  border-radius: 8rpx;
  font-weight: 700;
  font-family: monospace;
  font-size: 26rpx;
  letter-spacing: 1rpx;
}