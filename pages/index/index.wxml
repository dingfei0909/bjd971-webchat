<view class="container">
  <!-- 顶部 Hero 区域 -->
  <view class="hero-container">
    <view class="hero-gradient-overlay"></view>
    <view class="hero-content">
      <view class="hero-main">
        <view class="hero-meta">1997 梦开始的地方</view>
        <view class="hero-title">数本971</view>
      </view>
      <view class="hero-info">
        <text class="info-school">江苏大学</text>
        <text class="info-origin">原江苏理工大学</text>
        <text class="info-location">虎踞北路50号</text>
      </view>
    </view>
  </view>

  <!-- 照片轮播 -->
  <view class="carousel-section">
    <view class="section-title">
      <text class="title-text">📸 班级相册</text>
      <text class="title-more" bindtap="onTapPhotos">查看全部 ›</text>
    </view>
    <swiper
      class="carousel"
      indicator-dots="{{true}}"
      indicator-color="rgba(255, 140, 66, 0.3)"
      indicator-active-color="#FF8C42"
      autoplay="{{carouselPhotos.length > 1}}"
      interval="3000"
      duration="600"
      circular="{{true}}"
      bindtap="onTapCarousel"
    >
      <swiper-item wx:for="{{carouselPhotos}}" wx:key="_id" data-url="{{item.url}}">
        <view class="carousel-item">
          <image
            class="carousel-img"
            src="{{item.url}}"
            mode="aspectFill"
            lazy-load="{{true}}"
          />
          <view class="carousel-mask" wx:if="{{item.description}}">
            <text class="carousel-desc">{{item.description}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>

    <!-- 空状态 -->
    <view class="carousel-empty" wx:if="{{carouselPhotos.length === 0 && !carouselLoading}}">
      <view class="empty-icon">⭐</view>
      <view class="empty-text">还没有置顶照片</view>
      <view class="empty-hint">管理员可在照片墙点击照片设为置顶（最多6个）</view>
    </view>

    <!-- 加载中 -->
    <view class="carousel-loading" wx:if="{{carouselLoading}}">
      <text>加载中...</text>
    </view>
  </view>

  <!-- 入口卡片 -->
  <view class="entries">
    <view class="entry-card" bindtap="onTapPhotos">
      <view class="entry-icon">📷</view>
      <view class="entry-info">
        <view class="entry-title">照片墙</view>
        <view class="entry-desc">记录美好瞬间</view>
      </view>
      <view class="entry-arrow">›</view>
    </view>

    <view class="entry-card" bindtap="onTapAbout">
      <view class="entry-icon">📖</view>
      <view class="entry-info">
        <view class="entry-title">班级介绍</view>
        <view class="entry-desc">了解我们的故事</view>
      </view>
      <view class="entry-arrow">›</view>
    </view>
  </view>

  <!-- 寄语 -->
  <view class="motto">
    <view class="motto-text">{{classInfo.motto}}</view>
    <view class="motto-from">—— {{classInfo.className}} 全体同学</view>
  </view>

  <!-- 上传入口提示（让用户知道密码，体验完整功能） -->
  <view class="upload-hint">
    <view class="hint-title">📤 上传你的照片</view>
    <view class="hint-text">点击下方「照片墙」卡片进入</view>
    <view class="hint-text">点击「上传照片」按钮，输入密码「<text class="hint-password">bjd971</text>」即可上传</view>
    <view class="hint-text">管理员使用密码「<text class="hint-password">feiger</text>」</view>
  </view>

  <!-- 备案信息 -->
  <view class="beian">
    <view class="beian-row">
      <text class="beian-label">主办单位：</text>
      <text class="beian-value">丁飞</text>
    </view>
    <view class="beian-row">
      <text class="beian-label">服务名称：</text>
      <text class="beian-value">我们的数本971</text>
    </view>
    <view class="beian-row beian-link">
      <text class="beian-label">备案号：</text>
      <text class="beian-link-text" bindtap="onTapIcp">苏ICP备2026044365号-1X</text>
    </view>
    <view class="beian-row beian-link">
      <text class="beian-label">主备案号：</text>
      <text class="beian-link-text" bindtap="onTapIcpMain">苏ICP备2026044365号</text>
    </view>
    <view class="beian-tip">© 2026 我们的数本971</view>
  </view>
</view>