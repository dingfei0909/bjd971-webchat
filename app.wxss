/* app.wxss - 全局样式 */

page {
  background-color: #FFF8F0;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif;
  color: #333;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, #FF8C42 0%, #FFB347 100%);
  color: #FFF;
  border: none;
  border-radius: 50rpx;
  font-size: 30rpx;
  padding: 24rpx 48rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 140, 66, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-secondary {
  background-color: #FFF;
  color: #FF8C42;
  border: 2rpx solid #FF8C42;
  border-radius: 50rpx;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
}

.btn-secondary:active {
  background-color: #FFF8F0;
}

/* 通用卡片 */
.card {
  background-color: #FFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 通用文字 */
.text-primary { color: #FF8C42; }
.text-secondary { color: #999; }
.text-bold { font-weight: bold; }
.text-center { text-align: center; }

/* 加载动画 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 24rpx;
  opacity: 0.7;
}